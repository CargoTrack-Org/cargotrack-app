generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum ShipmentStatus {
  CREATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELAYED
  CANCELLED
}

// Document types known to the compliance agent.
// "OTHER" is the escape hatch for legacy / unknown types.
enum DocumentType {
  INVOICE
  BILL_OF_LADING
  SHIPPING_MANIFEST
  CUSTOMS
  PROOF_OF_DELIVERY
  SHIPPING_LABEL
  OTHER
}

enum ComplianceSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplianceStatus {
  PENDING   // Agent triggered but not yet complete
  PASSED    // All checks passed
  FAILED    // One or more CRITICAL/HIGH findings
  PARTIAL   // Checks ran but some documents were missing
}

enum FindingType {
  MISSING_DOCUMENT
  DATA_MISMATCH
  COMPLIANCE_RISK
  VALIDATION_ERROR
  DANGEROUS_GOODS_RISK
  PARTY_SCREENING_FLAG
  HS_CODE_MISMATCH
  VALUE_DISCREPANCY
  ROUTE_RESTRICTION
}

// ─── Core Domain ──────────────────────────────────────────────────────────────

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  name           String
  role           Role           @default(USER)
  profilePicture String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  shipments      Shipment[]
  notifications  Notification[]
}

model Shipment {
  id                    String             @id @default(uuid())
  trackingNumber        String             @unique
  title                 String
  senderName            String
  receiverName          String
  origin                String
  destination           String
  shipmentType          String
  weight                Float
  carrierName           String?
  description           String?
  estimatedDeliveryDate DateTime?
  status                ShipmentStatus     @default(CREATED)
  // ── vNext: Extended shipment intelligence fields ──────────────────────────
  // Commodity / cargo details for deeper AI analysis
  commodityType         String?            // e.g. "Electronics", "Chemicals", "Pharmaceuticals"
  hsCodeHint            String?            // User-provided HS tariff code hint
  isDangerousGoods      Boolean            @default(false)
  dangerousGoodsClass   String?            // IATA/IMDG DG class if isDangerousGoods
  incoterms             String?            // EXW, FOB, CIF, DDP, etc.
  declaredValue         Float?             // Declared customs value
  currencyCode          String?            @default("USD")
  // ── AI-replicated risk fields (from ComplianceReport, for fast list queries)
  aiRiskScore           Float?             // 0.0–1.0, replicated from ComplianceReport
  aiRiskLevel           String?            // LOW | MEDIUM | HIGH | CRITICAL
  // ─────────────────────────────────────────────────────────────────────────
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  userId                String
  user                  User               @relation(fields: [userId], references: [id])
  trackingEvents        TrackingEvent[]
  documents             ShipmentDocument[]
  complianceReport      ComplianceReport?
  aiBriefing            ShipmentAIBriefing?
}

model TrackingEvent {
  id          String         @id @default(uuid())
  status      ShipmentStatus
  location    String?
  description String
  timestamp   DateTime       @default(now())
  shipmentId  String
  shipment    Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model ShipmentDocument {
  id           String       @id @default(uuid())
  fileName     String
  originalName String
  fileType     String
  fileSize     Int
  documentType DocumentType @default(OTHER)
  uploadedAt   DateTime     @default(now())
  shipmentId   String
  shipment     Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  findings     ComplianceFinding[]
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── AI Intelligence Models ───────────────────────────────────────────────────

// ShipmentAIBriefing — Route intelligence generated by Nova Lite on shipment create.
// Written by ai-service directly to Postgres (same pattern as ComplianceReport).
// Provides instant AI context even before documents are uploaded.
model ShipmentAIBriefing {
  id                       String   @id @default(uuid())
  shipmentId               String   @unique
  shipment                 Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  // Corridor summary
  corridor                 String
  riskSummary              String   @db.Text
  // Document requirements predicted by Nova for this route
  requiredDocuments        Json     @default("[]")
  // Customs intelligence
  customsComplexity        String?  // LOW | MEDIUM | HIGH
  sanctionsStatus          String?  // CLEAR | WATCH | BLOCKED
  estimatedClearanceHours  Int?
  // Delay prediction
  delayProbability         Float?   // 0.0–1.0
  // Key risk flags (array of strings)
  keyRisks                 Json     @default("[]")
  // Nova-specific fields
  regulatoryNotes          String?  @db.Text
  modelId                  String?
  generatedAt              DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model ComplianceReport {
  id                     String             @id @default(uuid())
  shipmentId             String             @unique  // one report per shipment
  shipment               Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status                 ComplianceStatus   @default(PENDING)
  summary                String?
  // ── Risk Intelligence fields ──────────────────────────────────────────────
  overallRiskScore       Float?
  riskLevel              String?            // LOW | MEDIUM | HIGH | CRITICAL
  executiveSummary       String?            @db.Text
  recommendedDisposition String?            @db.Text
  modelId                String?
  modelConfidence        Float?
  processingTimeMs       Int?
  // ─────────────────────────────────────────────────────────────────────────
  agentRunId             String?
  findings               ComplianceFinding[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model ComplianceFinding {
  id                String             @id @default(uuid())
  reportId          String
  report            ComplianceReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  documentId        String?
  document          ShipmentDocument?  @relation(fields: [documentId], references: [id])
  findingType       FindingType
  severity          ComplianceSeverity
  description       String
  detail            Json?
  // ── Risk Intelligence fields ──────────────────────────────────────────────
  evidence          String?            @db.Text
  reasoning         String?            @db.Text
  confidenceScore   Float?
  recommendedAction String?            @db.Text
  // ─────────────────────────────────────────────────────────────────────────
  resolvedAt        DateTime?
  createdAt         DateTime           @default(now())
}
