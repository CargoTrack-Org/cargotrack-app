# CargoTrack — Environment Variables Reference
#
# Copy this file to .env and fill in your values.
# cp .env.example .env
#
# =============================================================
# DATABASE — External PostgreSQL (separate EC2 or Amazon RDS)
# =============================================================
DATABASE_HOST=your-db-ec2-private-ip-or-rds-endpoint
DATABASE_PORT=5432
DATABASE_NAME=cargotrack
DATABASE_USER=cargotrack
DATABASE_PASSWORD=change-me-strong-password

# Alternatively, set the full URL directly (overrides individual vars above):
# DATABASE_URL=postgresql://cargotrack:password@host:5432/cargotrack?schema=public

# =============================================================
# BACKEND
# =============================================================
JWT_SECRET=change-me-use-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=production
CORS_ORIGIN=*

# Admin account — created automatically on first startup
ADMIN_EMAIL=admin@cargotrack.com
ADMIN_PASSWORD=change-me-strong-admin-password

# =============================================================
# FRONTEND
# =============================================================
# URL prefix the React app uses to reach the API.
# Use /api when frontend nginx proxies to backend (recommended).
# Use http://<backend-ip>:4000/api for direct access mode.
VITE_API_BASE_URL=/api

# Backend URL injected into nginx at container startup (no rebuild needed).
# Set this to your backend EC2 private IP or hostname when deploying separately.
# Same-host deployment (both containers on one EC2): http://backend:4000
# Separate EC2 deployment: http://10.0.1.5:4000
BACKEND_URL=http://backend:4000

# =============================================================
# PORTS (optional — defaults shown)
# =============================================================
API_PORT=4000
APP_PORT=80
DB_PORT=5432
